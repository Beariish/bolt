import * from "../../test"

push_scope("pinning")

type T = { x: number, y: string }

test("pin weak T inference", fn {
    let t = weak T => { x: 10, y: "hello" }

    let st = pin t

    expect(typeof(t) == type(weak T), "Expected 'st' to be 'T?'")
    expect(typeof(st) == type(T?), "Expected 'st' to be 'T?'")
})

test("if-let pin inference", fn {
    let t = weak T => { x: 10, y: "hello" }


    ensure_branch()
    if let st = pin t {
        expect_branched(typeof(st) == type(T), "Expected 'st' to be 'T'")
    }

    expect(typeof(t) == type(weak T), "Expected 'st' to be 'T?'")
})

pop_scope()